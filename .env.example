# .env
# Arquivo local de ambiente (não versionado)

# ==========================================
# 1. Configurações de Ambiente e Admin
# ==========================================
# Configurações de ambiente (development, production)
ENV=development

# Senha para acessar o painel de ferramentas de desenvolvedor (DevTools)
# Usado em: lib/view/dev_tools_view.dart
DB_ADMIN_PASSWORD=sua_senha_devtools_aqui

# Bootstrap local opcional para a tela Admin Tools Setup.
# Deixe vazio em producao e prefira credenciais persistidas no Firestore.
# ADMIN_TOOLS_SETUP_USERNAME=admin
# ADMIN_TOOLS_SETUP_PASSWORD=defina_uma_senha_forte_somente_local

# Email do administrador para redirecionamento específico no login
# Usado em: lib/view/login_view.dart
ADMIN_EMAIL=admin@seu-dominio.com
DEV_EMAIL=dev@seu-dominio.com
# Telefone padrão do administrador (WhatsApp) caso não esteja no Firestore
# Usado em: lib/controller/firestore_service.dart
WHATSAPP_ADMIN=5511999999999
INSTAGRAM_ADMIN=https://www.instagram.com/seu_perfil_instagram_aqui/

# ==========================================
# 2. Firebase - Configuração Geral
# ==========================================
# Usado em: lib/firebase_options.dart
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_STORAGE_BUCKET=seu-project-id.firebasestorage.app

# ==========================================
# 3. Firebase - Web
# ==========================================
FIREBASE_WEB_API_KEY=sua_api_key_web_aqui
FIREBASE_WEB_APP_ID=1:123456789012:web:abcdef123456
FIREBASE_WEB_AUTH_DOMAIN=seu-project-id.firebaseapp.com

# Chave VAPID para identificação do servidor de push na Web
# Usado em: main.dart
VAPID_KEY=sua_vapid_key_publica

# Chave do Google reCAPTCHA para Firebase App Check na Web
# Usado em: main.dart
RECAPTCHA_SITE_KEY=sua_recaptcha_site_key_publica
# Alias opcionais aceitos pelo app (use apenas um deles):
# RECAPTCHA_SITE_KEY_CLIENT=sua_recaptcha_site_key_publica
# RECAPTCHA_SITE_KEY_CLIENT_V3=sua_recaptcha_site_key_publica
# IMPORTANTE: prefira RECAPTCHA_SITE_KEY como nome padrao.
# Nao use variaveis *_SERVER no app cliente.
# A secret key do reCAPTCHA deve ficar somente no Firebase App Check/Backend.

# ==========================================
# 4. Firebase - Android
# ==========================================
FIREBASE_ANDROID_API_KEY=sua_api_key_android_aqui
FIREBASE_ANDROID_APP_ID=1:123456789012:android:abcdef123456

# ==========================================
# 5. Firebase - iOS
# ==========================================
FIREBASE_IOS_API_KEY=sua_api_key_ios_aqui
FIREBASE_IOS_APP_ID=1:123456789012:ios:abcdef123456
FIREBASE_IOS_CLIENT_ID=123456789012-abcdef.apps.googleusercontent.com
FIREBASE_IOS_BUNDLE_ID=com.example.agenda

# ==========================================
# 6. Operações sensíveis via backend/Cloud Functions
# ==========================================
# O app cliente nao deve carregar FCM_SERVER_KEY, X_ACCESS_API_KEY ou
# X_MASTER_API_KEY. Mantenha esses valores apenas no backend.
PUSH_NOTIFICATION_FUNCTION_NAME=enviarNotificacaoPush
RANDOM_MESSAGES_FUNCTION_NAME=dispararMensagensAleatoriasClientesManual
# PUSH_NOTIFICATION_PROXY_URL=http://localhost:3000/api/push/send

# Segredos somente backend. Nao incluir no .env do app cliente.
# FCM_SERVER_KEY=
# X_ACCESS_API_KEY=
# X_MASTER_API_KEY=
# ACCESS_KEY_ID=

# ==========================================
# 7. Banco de Dados Secundário (PostgreSQL - Opcional)
# ==========================================
# PG_PASSWORD=crud123456
# DB_NAME=db_prova_crud
# DB_USER=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432


# ==========================================
# 8. Configurações de Teste / Mocks
# ==========================================
# Chaves utilizadas para mockar a inicialização do Firebase em testes
# Usado em: test/dev_tools_view_test.dart
FIREBASE_API_KEY=sua_api_key_firebase
FIREBASE_APP_ID=seu_app_id_firebase

# ==========================================
# 9. Outros
# ==========================================
BACKEND_URL=http://localhost:3000
web_warranty_app=seu_token_debug_legado_aqui
web_dev_app=seu_token_debug_legado_aqui
FIREBASE_APPCHECK_DEBUG_TOKEN=seu_token_debug_app_check_aqui

# Exemplo de formato (NAO use valores reais no .env.example)
# FIREBASE_WEB_API_KEY=sua_api_key_web_aqui
# FIREBASE_WEB_APP_ID=1:123456789012:web:abcdef123456
# FIREBASE_MESSAGING_SENDER_ID=123456789012
# FIREBASE_PROJECT_ID=seu-project-id
# FIREBASE_WEB_AUTH_DOMAIN=seu-project-id.firebaseapp.com
# FIREBASE_STORAGE_BUCKET=seu-project-id.firebasestorage.app