# .env.example
# Copie este arquivo para .env e preencha os valores do seu ambiente.
#
# IMPORTANTE:
# - Em Flutter Web e tambem nos bundles mobile, o conteudo de .env vai junto com o app.
# - Portanto, mantenha aqui apenas valores client-safe/publicos ou flags de desenvolvimento.
# - Segredos reais de servidor nao devem ser distribuidos no app cliente.
# - Regras do Firestore e payloads de autenticacao nao pertencem ao .env.

# ==========================================
# 1. Ambiente e identificadores do app
# ==========================================
ENV=development
ADMIN_EMAIL=admin@seu-dominio.com
DEV_EMAIL=dev@seu-dominio.com
WHATSAPP_ADMIN=5511999999999
DB_ADMIN_PASSWORD=sua_senha_devtools_aqui
INSTAGRAM_ADMIN=https://www.instagram.com/seu_perfil_instagram_aqui/

# Bootstrap local opcional para a tela Admin Tools Setup.
# Deixe vazio em producao e prefira credenciais persistidas no Firestore.
# ADMIN_TOOLS_SETUP_USERNAME=admin
# ADMIN_TOOLS_SETUP_PASSWORD=defina_uma_senha_forte_somente_local

# ==========================================
# 2. Firebase - Chaves publicas compartilhadas
# ==========================================
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_STORAGE_BUCKET=seu-project-id.firebasestorage.app

# ==========================================
# 3. Firebase - Web (publico)
# ==========================================
FIREBASE_WEB_API_KEY=sua_api_key_web_aqui
FIREBASE_WEB_APP_ID=1:123456789012:web:abcdef123456
FIREBASE_WEB_AUTH_DOMAIN=seu-project-id.firebaseapp.com
# Opcional se voce usar Analytics Web.
# FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# Chave publica para Web Push / App Check
VAPID_KEY=sua_vapid_key_publica
RECAPTCHA_SITE_KEY=sua_recaptcha_site_key_publica

# Tokens de debug do App Check para desenvolvimento local
FIREBASE_APPCHECK_DEBUG_TOKEN=seu_token_debug_app_check_aqui
web_warranty_app=seu_token_debug_legado_aqui
web_dev_app=seu_token_debug_legado_aqui

# ==========================================
# 4. Firebase - Android (publico)
# ==========================================
FIREBASE_ANDROID_API_KEY=sua_api_key_android_aqui
FIREBASE_ANDROID_APP_ID=1:123456789012:android:abcdef123456

# ==========================================
# 5. Firebase - iOS (publico)
# ==========================================
FIREBASE_IOS_API_KEY=sua_api_key_ios_aqui
FIREBASE_IOS_APP_ID=1:123456789012:ios:abcdef123456
FIREBASE_IOS_CLIENT_ID=123456789012-abcdef.apps.googleusercontent.com
FIREBASE_IOS_BUNDLE_ID=com.example.agenda

# ==========================================
# 6. Configuracoes nao sensiveis do app
# ==========================================
BACKEND_URL=http://localhost:3000

# ==========================================
# 7. Operacoes sensiveis via backend/Cloud Functions
# ==========================================
PUSH_NOTIFICATION_FUNCTION_NAME=enviarNotificacaoPush
RANDOM_MESSAGES_FUNCTION_NAME=dispararMensagensAleatoriasClientesManual
# PUSH_NOTIFICATION_PROXY_URL=https://seu-backend/api/push/send

# ==========================================
# 8. Testes / Mocks
# ==========================================
FIREBASE_API_KEY=sua_api_key_firebase_teste
FIREBASE_APP_ID=seu_app_id_firebase_teste

# ==========================================
# 9. Somente backend / NAO distribuir no cliente
# ==========================================
# Estes valores nao sao seguros em Flutter Web ou bundles mobile.
# Mantenha-os somente no backend, Cloud Functions ou no gerenciador de secrets.
# Nao adicione estes pares chave=valor no .env do app cliente.
# Configure somente no backend/secret manager:
# - FCM_SERVER_KEY
# - X_ACCESS_API_KEY
# - X_MASTER_API_KEY
# - ACCESS_KEY_ID
# - PG_PASSWORD
# - DB_NAME
# - DB_USER
# - DB_HOST
# - DB_PORT

# Observacao:
# - android/app/google-services.json e ios/Runner/GoogleService-Info.plist
#   continuam sendo exigidos pelos SDKs nativos do Firebase.
# - Os identificadores e API keys de cliente nesses arquivos sao publicos por natureza.
# - Eles nao substituem segredos de backend.
