# ==============================================================================
# Chronological sequence of commands used in the project
# ==============================================================================
# --- Comandos Principais para Configuração e Build do Projeto ---
 
# ------------------------------------------------------------------------------
# 1. Install Firebase and FlutterFire CLIs
# ------------------------------------------------------------------------------
# 1. Instalação e configuração de ferramentas
 npm install -g firebase-tools
 dart pub global activate flutterfire_cli
 
# ------------------------------------------------------------------------------
# 2. Set up PATH environment variables (example for bash)
# Note: You might need to add these to your shell profile file (e.g., ~/.bashrc)
# and then reload your shell (e.g., source ~/.bashrc).
# ------------------------------------------------------------------------------
# For firebase-tools:
export PATH="$PATH":"$(npm get prefix)/bin"
# For flutterfire_cli:
export PATH="$PATH":"$HOME/.pub-cache/bin"
# Adicionar o cache de pacotes do Dart ao PATH (necessário em alguns shells)
# Execute este comando se o flutterfire não for encontrado:
# export PATH="$PATH":"$HOME/.pub-cache/bin"
 
# ------------------------------------------------------------------------------
# 3. Login to Firebase
# The --no-localhost flag is useful in cloud environments like this one.
# ------------------------------------------------------------------------------
# 2. Login no Firebase
# O login pode exigir autenticação em um navegador. A flag --no-localhost é útil em ambientes remotos.
 firebase login --no-localhost
 
# ------------------------------------------------------------------------------
# 4. Configure the Flutter project
# Run these commands from the project root directory (/workspaces/Agenda)
# ------------------------------------------------------------------------------
# Enable web support
# 3. Configuração do projeto Flutter
# Ativa o suporte para a plataforma Web
 flutter config --enable-web
 
# Generate platform-specific files (if missing) for web, linux, etc.
# Adiciona as plataformas faltantes (Linux, Web, etc.) ao projeto existente no diretório atual
 flutter create .
 
# ------------------------------------------------------------------------------
# 5. Install system dependencies for building
# (for Debian/Ubuntu-based systems)
# ------------------------------------------------------------------------------
sudo apt update && sudo apt install -y chromium-browser ninja-build

# ------------------------------------------------------------------------------
# 6. Add Firebase dependencies to your Flutter project
# ------------------------------------------------------------------------------
# 4. Adicionar dependências do Firebase ao projeto Flutter
 flutter pub add firebase_core
 flutter pub add cloud_firestore
 flutter pub add firebase_messaging
 
# ------------------------------------------------------------------------------
# 7. Manage project dependencies
# ------------------------------------------------------------------------------
# 5. Sincronizar/Atualizar dependências do projeto
 flutter pub get
flutter pub outdated
 flutter pub upgrade
# To force upgrade to latest versions:
# flutter pub upgrade --major-versions
 
# To force framework upgrade:
flutter upgrade --force
# 6. Executar o projeto (ex: no navegador Chrome)
# Pode ser necessário instalar um navegador antes: sudo apt update && sudo apt install -y chromium-browser
flutter run -d chrome
 
# ------------------------------------------------------------------------------
# 8. Run and Build the application
# ------------------------------------------------------------------------------
flutter run
# 7. Build do projeto para diferentes plataformas
 flutter build web
 flutter build apk --release
 
# ------------------------------------------------------------------------------
# 9. Other commands used
# ------------------------------------------------------------------------------
# Clean the project
flutter clean

# Initialize Firebase features in the project (e.g., Hosting)
# 8. Inicializar o Firebase no projeto (para features como Hosting)
 firebase init
 
 
# ==============================================================================
# Unused context and notes from chat history
