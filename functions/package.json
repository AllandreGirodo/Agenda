{
  "name": "agenda-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "serve": "npm run build && firebase emulators:start --config ../lib/config/firebase.json --only functions",
    "deploy": "firebase deploy --config ../lib/config/firebase.json --only functions",
    "logs": "firebase functions:log --config ../lib/config/firebase.json"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
